[resource]
script = ExtResource("6_d0dbt")
nombre_nivel = "Cámara de Fauna"
nombre_hallazgo = "Cráneo de Smilodon"
hallazgo_if = 200.0
hallazgo_ic = 150.0
fi_inicial = 110.0
tecnicas_disponibles = Array[ExtResource("7_0i5gj")]([ExtResource("8_v5b75"), ExtResource("9_vs3d3"), ExtResource("10_d0dbt")])
especialistas_disponibles = Array[ExtResource("1_wv603")]([ExtResource("2_bjuea"), ExtResource("3_otg6q"), ExtResource("4_mocfe")])
duracion_nivel = 150.0
oleadas = Array[ExtResource("3_vkgxw")]([SubResource("Resource_8503b"), SubResource("Resource_tdych"), SubResource("Resource_3lhvt"), SubResource("Resource_pj281")])
eventos_posibles = Array[ExtResource("2_4vwjd")]([ExtResource("6_otg6q")])
hallazgo_info_real = "En Hoyo Negro se encontró el primer cráneo completo de Smilodon fatalis (tigre dientes de sable) hallado en México. Sus caninos medían hasta 28cm. Vivió hace entre 40,000 y 10,000 años y fue uno de los depredadores más temibles del Pleistoceno en América. La cueva actuó como trampannatural,  preservando sus restos."
hallazgo_descripcion_graciosa = "Tenía dientes más largos que tu teléfono celular.  La naturaleza claramente no entendía el concepto de  'suficiente'."
entradas_almanaque = Array[ExtResource("1_8503b")]([ExtResource("2_tdych"), ExtResource("3_3lhvt")])
metadata/_custom_type_script = "uid://dbmq8y8dxronl"
