hallazgo_info_real = "El Nohochichak xibalbahkah ('animal de grandes garras que vivía en el inframundo' en maya) es una nueva especie y género de perezoso terrestre gigante descubierta en Hoyo Negro. Su sinsacro fue extraído mediante un procedimiento meticuloso: fotografía previa, registro 3D de ubicación y profundidad, evaluación del conservador, autorización científica y embalaje especializado. Todo el proceso fue filmado. Sus restos están resguardados en el Laboratorio de Arqueozoología del INAH. 
"
hallazgo_descripcion_graciosa = "Su nombre en maya ya advertía que era intimidante."
entradas_almanaque = Array[ExtResource("1_fa4v6")]([ExtResource("2_blr2u"), ExtResource("3_vcxif")])
hallazgo_imagen = ExtResource("img_per")
