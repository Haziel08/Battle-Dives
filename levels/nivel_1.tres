danio_if_por_tiempo = 0.3
es_tutorial = true
pasos_tutorial = Array[ExtResource("13_vbyxe")]([ExtResource("14_0gwae"), ExtResource("15_lfua0"), ExtResource("16_ew18s"), ExtResource("17_bbmk1"), ExtResource("18_eqex1"), ExtResource("19_ew31r"), ExtResource("20_gryup"), ExtResource("21_klcdh"), ExtResource("22_rdryl"), ExtResource("23_dx0xt")])
pasos_extraccion = Array[ExtResource("7_c715l")]([ExtResource("8_um13t"), ExtResource("9_j05mq"), ExtResource("10_li3eh"), ExtResource("11_8qugv"), ExtResource("12_pjatk")])
hallazgo_info_real = "Las Marcas de Soga de Hoyo Negro son surcos tallados en la roca caliza de las paredes de la caverna. Fueron realizadas por humanos del Pleistoceno tardío hace aproximadamente 10,000 años, que descendieron intencionalmente a la cueva usando cuerdas para buscar agua dulce durante períodos de sequía extrema."
hallazgo_descripcion_graciosa = "Antes de que existieran los mapas, el GPS, las tiendas de conveniencia y el agua embotellada, nuestros ancestros bajaban a cuevas oscuras de 55 metros de profundidad con una cuerda y mucha determinación a buscar agua. La próxima vez que te quejes de que el Uber tardó 5 minutos, piénsalo."
entradas_almanaque = Array[ExtResource("1_eeibl")]([ExtResource("2_vmxgj"), ExtResource("3_vnwh0")])
metadata/_custom_type_script = "uid://dbmq8y8dxronl"
