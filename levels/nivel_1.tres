nombre_nivel = "Nivel 1: Entrada a Hoyo Negro"
nombre_hallazgo = "Marcas de Soga"
fi_inicial = 120.0
tecnicas_disponibles = Array[ExtResource("25_cyqql")]([ExtResource("26_u7i7f"), ExtResource("27_gfn4v")])
especialistas_disponibles = Array[ExtResource("1_o8eua")]([ExtResource("2_eeibl"), ExtResource("3_fno00")])
