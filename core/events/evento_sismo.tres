[ext_resource type="Script" uid="uid://cwvvi5ypt3s24" path="res://core/event_data.gd" id="1_eiqr3"]

[resource]
script = ExtResource("1_eiqr3")
nombre = "Sismo"
tipo = "sismo"
duracion = 1.0
danio_fisico_instantaneo = 25.0
info_real = "La Península de Yucatán tiene actividad sísmica moderada relacionada con fallas geológicas del Caribe. Un sismo puede desestabilizar bloques de roca caliza dentro de las cuevas, alterar el flujo de agua subterránea y en casos extremos, colapsar paredes que durante siglos habían protegido hallazgos arqueológicos."
descripcion_graciosa = "La cueva que sobrevivió 13,000 años intacta puede verse afectada por un sismo en minutos. La geología no acepta quejas ni apelaciones."
metadata/_custom_type_script = "uid://cwvvi5ypt3s24"
