[ext_resource type="Script" uid="uid://cn5ubsk5eln5s" path="res://entities/specialists/technique_data.gd" id="1_bynpo"]

[resource]
script = ExtResource("1_bynpo")
nombre = "Policía Marítima"
costo = 130
hp = 150.0
danio = 40.0
velocidad = 90.0
velocidad_ataque = 1.2
radio_deteccion = 70.0
efectivo_contra = Array[String](["saqueador"])
multiplicador_danio = 3.0
color_debug = Color(8.4228816e-07, 0, 0.46257508, 1)
info_real = "La Secretaría de Marina (SEMAR) y la Guardia Nacional son las autoridades encargadas de proteger el patrimonio subacuático en aguas mexicanas. La Ley Federal sobre Monumentos y Zonas Arqueológicos establece penas de hasta 12 años de prisión por saqueo de patrimonio arqueológico subacuático en México."
descripcion_graciosa = "La única tropa del juego que puede decir 'quedas detenido' y que eso signifique algo legalmente. El saqueador tiene muy malos días cuando aparece la Policía Marítima."
metadata/_custom_type_script = "uid://cn5ubsk5eln5s"
