[resource]
script = ExtResource("1_4naqx")
nombre = "Oceanógrafo"
costo = 75
duracion = 25.0
pasiva_reduce_prob_evento = 0.3
tiene_activa = true
nombre_activa = "Pronóstico"
color_debug = Color(3.272891e-06, 0.946183, 0.9248272, 1)
info_real = "Los oceanógrafos en proyectos de cuevas subacuáticas monitorean temperatura, salinidad, pH, oxígeno disuelto y flujo de corrientes. En la Península de Yucatán, el sistema de cuevas subterráneas (cenotes) está conectado al mar Caribe, haciendo que eventos como huracanes o mareas afecten directamente las condiciones internas de Hoyo Negro."
descripcion_graciosa = "Predice huracanes para que el equipo no baje a bucear el día en que la cueva decide convertirse en una lavadora."
metadata/_custom_type_script = "uid://jp81cwh1fegm"
