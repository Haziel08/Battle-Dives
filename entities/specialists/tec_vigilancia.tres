script = ExtResource("1_l1ngh")
nombre = "Vigilancia"
costo = 60
danio = 12.0
velocidad = 50.0
radio_deteccion = 100.0
efectivo_contra = Array[String](["saqueador", "buceador"])
color_debug = Color(0.50147754, 0.56512266, 0.09797313, 1)
spritesheet_path = "res://assets/vigilancia_spritesheet.png"
spritesheet_hframes = 4
info_real = "La vigilancia de sitios arqueológicos subacuáticos combina cámaras submarinas, patrullaje por buzos y registro de accesos. El INAH y el Gobierno de Quintana Roo coordinan la protección legal de Hoyo Negro, que está catalogado como Zona de Monumentos Arqueológicos. El acceso no autorizado es un delito federal en México."
descripcion_graciosa = "La cámara submarina no tiene Wi-Fi, el buzo de patrulla tiene frío, y el saqueador tiene que explicarle a la policía marítima por qué traía un fósil de perezoso gigante en la mochila."
