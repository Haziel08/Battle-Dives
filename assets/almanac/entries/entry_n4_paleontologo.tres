[resource]
script = ExtResource("1_qupjp")
titulo = "Nueva Especie: Nohochichak xibalbahkah"
contenido = "Nohochichak xibalbahkah significa 'animal de grandes garras que vivía en el inframundo' en lengua maya yucateca — un nombre que los investigadores consideraron perfectamente apropiado.

Es un género Y especie completamente nuevos para la ciencia, descubiertos exclusivamente en Hoyo Negro. Pertenece a los perezosos terrestres gigantes (Megatheriidae), que podían alcanzar el tamaño de un elefante actual.

Su hallazgo demuestra que la diversidad de megafauna en Yucatán durante el Pleistoceno era significativamente mayor de lo que se conocía."
especialista_requerido = "Paleontólogo"
nivel_requerido = 3
metadata/_custom_type_script = "uid://ba7n312g3mwvn"
