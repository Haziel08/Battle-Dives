[resource]
script = ExtResource("1_rpw35")
titulo = "Identificación: Cuvieronius hyodon"
contenido = "El Cuvieronius hyodon (gonfoterio) pertenecía a la familia Gomphotheriidae, parientes extintos de los elefantes. Se distinguía por sus colmillos en espiral y su tamaño ligeramente menor al de los elefantes africanos.

En Hoyo Negro se encontraron restos de al menos 42 animales del Pleistoceno tardío de 13 especies. El gonfoterio es una de las 7 especies EXTINTAS identificadas en el sitio.
"
especialista_requerido = "Paleontóloga"
nivel_requerido = 2
metadata/_custom_type_script = "uid://ba7n312g3mwvn"
